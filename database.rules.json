{
  "rules": {

    /* ── Users ─────────────────────────────────── */
    "users": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'super_admin' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'instructor')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'super_admin')"
      }
    },

    /* ── Companies ─────────────────────────────── */
    "companies": {
      ".read":  "auth != null && root.child('users').child(auth.uid).child('role').val() === 'super_admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'super_admin'"
    },

    /* ── Branches ──────────────────────────────── */
    "branches": {
      ".read":  "auth != null",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'super_admin'"
    },

    /* ── Departments ───────────────────────────── */
    "departments": {
      ".read":  "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'super_admin' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin')"
    },

    /* ── Trainings (기존) ──────────────────────── */
    "trainings": {
      ".read":  "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin' || root.child('users').child(auth.uid).child('role').val() === 'instructor')"
    },

    /* ── Assignments (기존) ────────────────────── */
    "trainingAssignments": {
      ".read":  "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin' || root.child('users').child(auth.uid).child('role').val() === 'instructor')",
      "$trainingId": {
        "$uid": { ".read": "auth != null && auth.uid === $uid" }
      },
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin' || root.child('users').child(auth.uid).child('role').val() === 'instructor')"
    },
    "userAssignments": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'instructor')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin' || root.child('users').child(auth.uid).child('role').val() === 'instructor')"
      }
    },

    /* ── Completions (기존) ────────────────────── */
    "trainingCompletions": {
      ".read":  "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin' || root.child('users').child(auth.uid).child('role').val() === 'instructor')",
      "$trainingId": {
        "$uid": {
          ".read":  "auth != null && auth.uid === $uid",
          ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin')"
        }
      }
    },
    "userCompletions": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'instructor')",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin')"
      }
    },

    /* ══════════════════════════════════════════
       ★ 신규: Training Items
         .indexOn: companyId, instructorId, createdBy
    ══════════════════════════════════════════ */
    "trainingItems": {
      ".read":  "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".indexOn": ["companyId", "instructorId", "createdBy"]
    },

    /* ══════════════════════════════════════════
       ★ 신규: Training Sessions
         .indexOn: itemId, companyId
    ══════════════════════════════════════════ */
    "trainingSessions": {
      ".read":  "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".indexOn": ["itemId", "companyId", "createdBy"]
    },

    /* ══════════════════════════════════════════
       ★ 신규: Session Assignments
    ══════════════════════════════════════════ */
    "sessionAssignments": {
      ".read":  "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')"
    },
    "userSessionAssignments": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')"
      }
    },

    /* ══════════════════════════════════════════
       ★ 신규: Session Completions
    ══════════════════════════════════════════ */
    "sessionCompletions": {
      ".read":  "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')"
    },
    "userSessionCompletions": {
      "$uid": {
        ".read":  "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin')",
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'instructor' || root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')"
      }
    },

    /* ── Materials ─────────────────────────────── */
    "materials": {
      ".read":  "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')"
    },

    /* ── Templates ─────────────────────────────── */
    "templates": {
      ".read":  "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'hq_admin'"
    },

    /* ── Announcements ─────────────────────────── */
    "announcements": {
      ".read":  "auth != null",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')"
    },

    /* ── Settings ──────────────────────────────── */
    "settings": {
      ".read":  "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin' || root.child('users').child(auth.uid).child('role').val() === 'instructor')",
      ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() === 'hq_admin' || root.child('users').child(auth.uid).child('role').val() === 'super_admin')"
    },

    /* ── Lesson Plans / Cue Cards ──────────────── */
    "lessonPlans": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "cueCards": {
      "$uid": {
        ".read":  "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    }

  }
}
